import pandas as pd
import numpy as np
from sklearn.linear_model import LinearRegression
from sklearn.metrics import mean_squared_error, r2_score
df = pd.read_csv('train.csv')
missing_ratios = df.isnull().mean()
cols_to_drop = missing_ratios[missing_ratios > 0.4].index
df.drop(columns=cols_to_drop, inplace=True)
df.drop(columns=['Id'], inplace=True)
numerical_cols = df.select_dtypes(include=['int64', 'float64']).columns
categorical_cols = df.select_dtypes(include=['object']).columns
for col in numerical_cols:
    if df[col].isnull().sum() > 0:
        df[col] = df[col].fillna(df[col].median())
for col in categorical_cols:
    if df[col].isnull().sum() > 0:
        df[col] = df[col].fillna(df[col].mode()[0])
df = pd.get_dummies(df, columns=categorical_cols, drop_first=True)
X = df.drop('SalePrice', axis=1)
y = df['SalePrice']
lr = LinearRegression()
lr.fit(X, y)
y_pred = lr.predict(X)
mse = mean_squared_error(y, y_pred)
r2 = r2_score(y, y_pred)
rmse = np.sqrt(mse)
print("Coefficients shape:", lr.coef_.shape)
print("Intercept:", lr.intercept_)
print("Mean Squared Error:", mse)
print("R-squared Score:", r2)
print("Root meant Square error : ",rmse)
test_df = pd.read_csv('test.csv')
test_df.drop(columns=cols_to_drop, inplace=True)
if 'Id' in test_df.columns:
    ids = test_df['Id']
    test_df.drop(columns=['Id'], inplace=True)
for col in test_df.select_dtypes(include=['int64', 'float64']).columns:
    if test_df[col].isnull().sum() > 0:
        test_df[col] = test_df[col].fillna(test_df[col].median())
for col in test_df.select_dtypes(include=['object']).columns:
    if test_df[col].isnull().sum() > 0:
        test_df[col] = test_df[col].fillna(test_df[col].mode()[0])
test_df = pd.get_dummies(test_df, columns=test_df.select_dtypes(include=['object']).columns, drop_first=True)
test_df = test_df.reindex(columns=X.columns, fill_value=0)
test_predictions = lr.predict(test_df)
output = pd.DataFrame({
    'Id': ids,
    'SalePrice': test_predictions
})
output.to_csv('predicted_test_output.csv', index=False)
print("Predictions saved to 'predicted_test_output.csv'") 
